<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#13131F"
    android:paddingHorizontal="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#3A3D52"
        android:backgroundTint="#3A3D52"/>

    <!-- ═══ LAYOUT FORM (tampil saat belum submit) ═══════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Judul -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Beri Ulasan"
            android:textColor="#F0F6FC"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <!-- Nama loket -->
        <TextView
            android:id="@+id/tvNamaLoket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loket Administrasi"
            android:textColor="#A855F7"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- RatingBar bintang 5 -->
        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:numStars="5"
            android:stepSize="1"
            android:rating="5"
            android:progressTint="#F59E0B"
            android:secondaryProgressTint="#2A2D3E"
            android:layout_marginBottom="8dp"/>

        <!-- Label teks rating -->
        <TextView
            android:id="@+id/tvRatingLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Luar Biasa! ⭐⭐⭐⭐⭐"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Input komentar opsional -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Komentar (opsional)"
            app:hintTextColor="#8B949E"
            app:boxStrokeColor="#2A2D3E"
            app:boxBackgroundColor="#1E1E2E"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etKomentar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:maxLines="5"
                android:gravity="top"
                android:maxLength="500"
                android:inputType="textMultiLine|textCapSentences"
                android:textColor="#F0F6FC"
                android:textColorHint="#3A3D52"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ProgressBar (tampil saat loading) -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="#A855F7"
            android:layout_marginBottom="8dp"/>

        <!-- Tombol kirim -->
        <Button
            android:id="@+id/btnKirim"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Kirim Ulasan"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_gradient"
            android:layout_marginBottom="12dp"/>

        <!-- Teks lewati -->
        <TextView
            android:id="@+id/tvLewati"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lewati"
            android:textColor="#8B949E"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- ═══ LAYOUT SUKSES (tampil setelah berhasil submit) ══════════════════ -->
    <LinearLayout
        android:id="@+id/layoutSukses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="56sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Terima Kasih!"
            android:textColor="#F0F6FC"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ulasan Anda membantu kami\nmeningkatkan pelayanan."
            android:textColor="#8B949E"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>

</LinearLayout>