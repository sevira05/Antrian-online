<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_white"
    android:paddingHorizontal="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/border_default"/>

    <!-- ═══ LAYOUT FORM ═══ -->
    <LinearLayout
        android:id="@+id/layoutForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Nama Loket -->
        <TextView
            android:id="@+id/tvNamaLoket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nama Loket"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bagaimana pengalaman Anda?"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Rating Bar -->
        <RatingBar
            android:id="@+id/ratingBar"
            style="?android:attr/ratingBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:numStars="5"
            android:stepSize="1"
            android:rating="5"
            android:progressTint="@color/amber_text"
            android:layout_marginBottom="8dp"/>

        <!-- Label Rating -->
        <TextView
            android:id="@+id/tvRatingLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Luar Biasa! ⭐⭐⭐⭐⭐"
            android:textColor="@color/blue_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Komentar - pakai style bawaan Material tanpa custom attr -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Komentar (opsional)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etKomentar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:gravity="top"
                android:inputType="textMultiLine"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/blue_primary"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Tombol Kirim -->
        <Button
            android:id="@+id/btnKirim"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Kirim Ulasan"
            android:textColor="@color/text_white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:stateListAnimator="@null"
            android:layout_marginBottom="10dp"/>

        <!-- Lewati -->
        <TextView
            android:id="@+id/tvLewati"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lewati"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- ═══ LAYOUT SUKSES ═══ -->
    <LinearLayout
        android:id="@+id/layoutSukses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="52sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Terima Kasih!"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ulasan Anda sudah kami terima."
            android:textColor="@color/text_muted"
            android:textSize="13sp"/>

    </LinearLayout>

</LinearLayout>