<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#13131F"
        app:title="Beri Ulasan"
        app:titleTextColor="#F0F6FC"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nama Loket -->
            <TextView
                android:id="@+id/tvNamaLoket"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama Loket"
                android:textColor="#F0F6FC"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bagaimana pengalaman Anda?"
                android:textColor="#8B949E"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- RatingBar -->
            <RatingBar
                android:id="@+id/ratingBar"
                style="?android:attr/ratingBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:numStars="5"
                android:stepSize="1"
                android:rating="5"
                android:progressTint="#F59E0B"
                android:layout_marginBottom="8dp"/>

            <!-- Label Rating -->
            <TextView
                android:id="@+id/tvRatingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Luar Biasa! ⭐⭐⭐⭐⭐"
                android:textColor="#A855F7"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Komentar -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Komentar (opsional)"
                android:layout_marginBottom="32dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etKomentar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:gravity="top"
                    android:textColor="#F0F6FC"
                    android:inputType="textMultiLine"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tombol Kirim -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKirim"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Kirim Ulasan"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#A855F7"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Tombol Batal -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Lewati"
                android:textColor="#8B949E"
                android:textSize="15sp"
                app:backgroundTint="@android:color/transparent"
                app:strokeColor="#2D2D44"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>