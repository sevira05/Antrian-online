<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardLoket"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@android:color/white"
    app:strokeColor="@color/blue_primary"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- Row: Icon + Info + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Icon -->
            <TextView
                android:id="@+id/tvIcon"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:textSize="20sp"
                android:background="@drawable/bg_icon_loket"
                android:text="🏛️"/>

            <!-- Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvNamaLoket"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Layanan Umum"
                    android:textColor="@color/navy_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPengelola"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengelola: -"
                    android:textColor="@color/blue_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp"/>

                <TextView
                    android:id="@+id/tvJam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:00 - 16:00"
                    android:textColor="@color/blue_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp"/>

            </LinearLayout>

            <!-- Status -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUKA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"/>

                <TextView
                    android:id="@+id/tvSisaKuota"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/20 antrian"
                    android:textColor="@color/blue_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressKuota"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/blue_primary"
            android:progressBackgroundTint="@color/bg_page"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>