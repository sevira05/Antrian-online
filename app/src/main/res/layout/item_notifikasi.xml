<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#13131F">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">
        <View android:id="@+id/viewUnread" android:layout_width="3dp" android:layout_height="match_parent" android:background="@drawable/bg_button_gradient" android:layout_marginEnd="12dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/tvJudul" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF" android:layout_marginBottom="4dp" android:text="Judul"/>
            <TextView android:id="@+id/tvPesan" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#8B8FA8" android:layout_marginBottom="6dp" android:text="Pesan"/>
            <TextView android:id="@+id/tvWaktu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="#3A3D52" android:text="Waktu"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>