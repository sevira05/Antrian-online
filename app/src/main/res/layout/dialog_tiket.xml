<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="@drawable/bg_card_dark">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tiket Antrian 🎫" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF" android:gravity="center" android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tvNoAntrian" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="64sp" android:textStyle="bold" android:textColor="#A855F7" android:gravity="center" android:layout_marginBottom="4dp" android:text="A-001"/>
    <TextView android:id="@+id/tvNamaLoket" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:textColor="#8B8FA8" android:gravity="center" android:layout_marginBottom="20dp" android:text="Nama Loket"/>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2D3E" android:layout_marginBottom="20dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Posisi Antrian" android:textColor="#8B8FA8" android:textSize="13sp"/>
        <TextView android:id="@+id/tvPosisi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" android:text="-"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Estimasi Tunggu" android:textColor="#8B8FA8" android:textSize="13sp"/>
        <TextView android:id="@+id/tvEstimasi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" android:text="-"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="20dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Waktu Ambil" android:textColor="#8B8FA8" android:textSize="13sp"/>
        <TextView android:id="@+id/tvTanggalJam" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" android:text="-"/>
    </LinearLayout>
    <TextView android:id="@+id/tvInfo" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="⏰ Notifikasi akan muncul saat giliran Anda tiba" android:textSize="12sp" android:textColor="#F59E0B" android:background="#1F1A00" android:padding="12dp" android:layout_marginBottom="20dp"/>
    <Button android:id="@+id/btnTutup" android:layout_width="match_parent" android:layout_height="52dp" android:text="Tutup" android:textColor="#FFFFFF" android:textStyle="bold" android:background="@drawable/bg_button_gradient" android:stateListAnimator="@null"/>
</LinearLayout>