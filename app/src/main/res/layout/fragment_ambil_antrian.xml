<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- Header Navy -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy_dark"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ambil Nomor Antrian"
            android:textColor="@color/text_white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih layanan yang Anda butuhkan"
            android:textColor="@color/blue_muted"
            android:textSize="12sp"
            android:layout_marginTop="3dp"/>

    </LinearLayout>

    <!-- ProgressBar loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:indeterminateTint="@color/blue_primary"
        android:visibility="gone"/>

    <!-- Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- INFO BOX -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_notif_blue"
                android:padding="12dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ INFORMASI"
                    android:textStyle="bold"
                    android:textColor="@color/blue_primary"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengambilan antrian mulai 06:00 pagi hingga jam layanan. Maks. 20 nomor per layanan/hari."
                    android:textSize="12sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Selected Loket -->
            <TextView
                android:id="@+id/tvSelectedLoket"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/blue_primary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <!-- Judul -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Layanan:"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="8dp"/>

            <!-- LIST LAYANAN -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLoket"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAmbil"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🎫 AMBIL NOMOR ANTRIAN"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/blue_primary"
                app:cornerRadius="12dp"
                android:layout_marginTop="12dp"
                android:enabled="false"/>

        </LinearLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>