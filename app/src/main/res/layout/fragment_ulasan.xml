<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F6F8FC"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy_dark"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ulasan"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Berikan pengalaman Anda terhadap layanan"
            android:textColor="@color/blue_soft"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- FORM CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- NAMA -->
            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:minHeight="48dp"
                android:padding="12dp"
                android:hint="Nama Anda"
                android:background="@drawable/bg_input"/>

            <!-- RATING -->
            <EditText
                android:id="@+id/etRating"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:minHeight="48dp"
                android:padding="12dp"
                android:hint="Rating (1 - 5)"
                android:inputType="number"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"/>

            <!-- KOMENTAR -->
            <EditText
                android:id="@+id/etKomentar"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:minHeight="80dp"
                android:padding="12dp"
                android:hint="Tulis pengalaman Anda..."
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:gravity="top"/>

            <!-- BUTTON -->
            <Button
                android:id="@+id/btnKirim"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:minHeight="48dp"
                android:text="Kirim Ulasan"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/navy_dark"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- TITLE LIST -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ulasan Terbaru"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="6dp"/>

    <!-- LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUlasan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="10dp"
        android:clipToPadding="false"
        android:contentDescription="Daftar ulasan pengguna"/>

</LinearLayout>