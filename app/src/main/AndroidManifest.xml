<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- PERMISSIONS -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Wajib untuk Android 13+ agar notifikasi bisa muncul -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Untuk getaran -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- Untuk full-screen intent (muncul saat layar terkunci) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AntrianOnline"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- LOGIN -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- REGISTER -->
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"/>

        <!-- HOME -->
        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false"/>

        <!-- PROFIL -->
        <activity
            android:name=".ui.profil.EditProfilActivity"
            android:exported="false"/>

        <activity
            android:name=".ui.profil.GantiPasswordActivity"
            android:exported="false"/>

        <!-- FITUR ULASAN -->
        <activity
            android:name=".ui.ulasan.KirimUlasanActivity"
            android:exported="false"/>

    </application>

</manifest>